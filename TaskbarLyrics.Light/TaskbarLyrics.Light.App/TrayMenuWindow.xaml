<Window x:Class="TaskbarLyrics.Light.App.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="230"
        Height="412"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="TrayMenuBackgroundBrush" Color="#1E1E1E" />
        <SolidColorBrush x:Key="TrayMenuHoverBrush" Color="#303030" />
        <SolidColorBrush x:Key="TrayMenuPressedBrush" Color="#3A3A3A" />
        <SolidColorBrush x:Key="TrayMenuTextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TrayMenuSeparatorBrush" Color="#4A4A4A" />

        <Style x:Key="TrayMenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource TrayMenuHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource TrayMenuPressedBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="Top" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Chrome" Property="CornerRadius" Value="8,8,0,0" />
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="Bottom" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Chrome" Property="CornerRadius" Value="0,0,8,8" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TraySubmenuButtonStyle" TargetType="Button" BasedOn="{StaticResource TrayMenuButtonStyle}">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="10,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Border CornerRadius="8"
                Background="{DynamicResource TrayMenuBackgroundBrush}"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32" />
                    <RowDefinition Height="32" />
                    <RowDefinition Height="32" />
                    <RowDefinition Height="32" />
                    <RowDefinition Height="32" />
                    <RowDefinition Height="32" />
                    <RowDefinition Height="32" />
                    <RowDefinition Height="32" />
                    <RowDefinition Height="32" />
                    <RowDefinition Height="32" />
                    <RowDefinition Height="1" />
                    <RowDefinition Height="32" />
                    <RowDefinition Height="1" />
                    <RowDefinition Height="32" />
                </Grid.RowDefinitions>

                <Button Grid.Row="0" Style="{StaticResource TrayMenuButtonStyle}" Tag="Top" Click="ToggleLyricsButton_Click" MouseEnter="CloseSubmenuOnMouseEnter">
                    <TextBlock x:Name="LyricsWindowText" Text="显示歌词" VerticalAlignment="Center" Foreground="{DynamicResource TrayMenuTextBrush}" FontFamily="Microsoft YaHei UI" FontSize="12.5" />
                </Button>

                <Button Grid.Row="1" Style="{StaticResource TrayMenuButtonStyle}" Click="ToggleTranslationButton_Click" MouseEnter="CloseSubmenuOnMouseEnter">
                    <TextBlock x:Name="TranslationText" Text="显示翻译" VerticalAlignment="Center" Foreground="{DynamicResource TrayMenuTextBrush}" FontFamily="Microsoft YaHei UI" FontSize="12.5" />
                </Button>

                <Button Grid.Row="2" Style="{StaticResource TrayMenuButtonStyle}" Click="RematchLyricsButton_Click" MouseEnter="CloseSubmenuOnMouseEnter">
                    <TextBlock Text="重新匹配当前歌词" VerticalAlignment="Center" Foreground="{DynamicResource TrayMenuTextBrush}" FontFamily="Microsoft YaHei UI" FontSize="12.5" />
                </Button>

                <Button x:Name="SpectrumStyleButton" Grid.Row="3" Style="{StaticResource TrayMenuButtonStyle}" MouseEnter="SpectrumStyleButton_MouseEnter" Click="SpectrumStyleButton_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SpectrumStyleText" Text="频谱设置" VerticalAlignment="Center" Foreground="{DynamicResource TrayMenuTextBrush}" FontFamily="Microsoft YaHei UI" FontSize="12.5" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1" Text="›" VerticalAlignment="Center" Foreground="{DynamicResource TrayMenuTextBrush}" FontFamily="Microsoft YaHei UI" FontSize="16" Margin="8,0,0,0" />
                    </Grid>
                </Button>

                <Button x:Name="SongProgressStyleButton" Grid.Row="4" Style="{StaticResource TrayMenuButtonStyle}" MouseEnter="SongProgressStyleButton_MouseEnter" Click="SongProgressStyleButton_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SongProgressStyleText" Text="进度设置" VerticalAlignment="Center" Foreground="{DynamicResource TrayMenuTextBrush}" FontFamily="Microsoft YaHei UI" FontSize="12.5" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1" Text="›" VerticalAlignment="Center" Foreground="{DynamicResource TrayMenuTextBrush}" FontFamily="Microsoft YaHei UI" FontSize="16" Margin="8,0,0,0" />
                    </Grid>
                </Button>

                <Button x:Name="CoverStyleButton" Grid.Row="5" Style="{StaticResource TrayMenuButtonStyle}" MouseEnter="CoverStyleButton_MouseEnter" Click="CoverStyleButton_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CoverStyleText" Text="封面设置" VerticalAlignment="Center" Foreground="{DynamicResource TrayMenuTextBrush}" FontFamily="Microsoft YaHei UI" FontSize="12.5" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1" Text="›" VerticalAlignment="Center" Foreground="{DynamicResource TrayMenuTextBrush}" FontFamily="Microsoft YaHei UI" FontSize="16" Margin="8,0,0,0" />
                    </Grid>
                </Button>

                <Button x:Name="TextEffectStyleButton" Grid.Row="6" Style="{StaticResource TrayMenuButtonStyle}" MouseEnter="TextEffectStyleButton_MouseEnter" Click="TextEffectStyleButton_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TextEffectStyleText" Text="文字效果设置" VerticalAlignment="Center" Foreground="{DynamicResource TrayMenuTextBrush}" FontFamily="Microsoft YaHei UI" FontSize="12.5" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1" Text="›" VerticalAlignment="Center" Foreground="{DynamicResource TrayMenuTextBrush}" FontFamily="Microsoft YaHei UI" FontSize="16" Margin="8,0,0,0" />
                    </Grid>
                </Button>

                <Button x:Name="TransitionStyleButton" Grid.Row="7" Style="{StaticResource TrayMenuButtonStyle}" MouseEnter="TransitionStyleButton_MouseEnter" Click="TransitionStyleButton_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TransitionStyleText" Text="切换动画设置" VerticalAlignment="Center" Foreground="{DynamicResource TrayMenuTextBrush}" FontFamily="Microsoft YaHei UI" FontSize="12.5" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1" Text="›" VerticalAlignment="Center" Foreground="{DynamicResource TrayMenuTextBrush}" FontFamily="Microsoft YaHei UI" FontSize="16" Margin="8,0,0,0" />
                    </Grid>
                </Button>

                <Button Grid.Row="8" Style="{StaticResource TrayMenuButtonStyle}" Click="ClearCacheButton_Click" MouseEnter="CloseSubmenuOnMouseEnter">
                    <TextBlock Text="清除歌词缓存" VerticalAlignment="Center" Foreground="{DynamicResource TrayMenuTextBrush}" FontFamily="Microsoft YaHei UI" FontSize="12.5" />
                </Button>

                <Button Grid.Row="9" Style="{StaticResource TrayMenuButtonStyle}" Click="SettingsButton_Click" MouseEnter="CloseSubmenuOnMouseEnter">
                    <TextBlock Text="设置" VerticalAlignment="Center" Foreground="{DynamicResource TrayMenuTextBrush}" FontFamily="Microsoft YaHei UI" FontSize="12.5" />
                </Button>

                <Border Grid.Row="10" Height="1" VerticalAlignment="Center" Background="{DynamicResource TrayMenuSeparatorBrush}" />

                <Button Grid.Row="11" Style="{StaticResource TrayMenuButtonStyle}" Click="SpectrumTuningButton_Click" MouseEnter="CloseSubmenuOnMouseEnter">
                    <TextBlock Text="频谱调试" VerticalAlignment="Center" Foreground="{DynamicResource TrayMenuTextBrush}" FontFamily="Microsoft YaHei UI" FontSize="12.5" />
                </Button>

                <Border Grid.Row="12" Height="1" VerticalAlignment="Center" Background="{DynamicResource TrayMenuSeparatorBrush}" />

                <Button Grid.Row="13" Style="{StaticResource TrayMenuButtonStyle}" Tag="Bottom" Click="ExitButton_Click" MouseEnter="CloseSubmenuOnMouseEnter">
                    <TextBlock Text="退出" VerticalAlignment="Center" Foreground="{DynamicResource TrayMenuTextBrush}" FontFamily="Microsoft YaHei UI" FontSize="12.5" />
                </Button>
            </Grid>
        </Border>

        <Popup x:Name="SubmenuPopup"
               Placement="Right"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               StaysOpen="True"
               MouseEnter="SubmenuPopup_MouseEnter"
               MouseLeave="SubmenuPopup_MouseLeave">
            <Border MinWidth="178"
                    Margin="6,0,0,0"
                    CornerRadius="8"
                    Background="{DynamicResource TrayMenuBackgroundBrush}"
                    BorderBrush="{DynamicResource TrayMenuSeparatorBrush}"
                    BorderThickness="1"
                    ClipToBounds="True">
                <StackPanel x:Name="SubmenuItemsPanel" />
            </Border>
        </Popup>
    </Grid>
</Window>
