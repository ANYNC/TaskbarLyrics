                            <TextBlock Text="位置与层级" Style="{StaticResource SettingsGroupTitleStyle}" />
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="强制置顶歌词窗口" FontWeight="SemiBold" />
                                        <TextBlock Text="关闭后歌词窗口不再始终位于最前，便于操作其他窗口。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="ForceAlwaysOnTopCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="280" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="水平锚点" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <ComboBox x:Name="HorizontalAnchorCombo" Grid.Column="1" Style="{StaticResource SettingsComboBoxStyle}">
                                        <ComboBoxItem Content="左侧" Tag="Left" />
                                        <ComboBoxItem Content="居中" Tag="Center" />
                                        <ComboBoxItem Content="右侧" Tag="Right" />
                                    </ComboBox>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="280" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="X 偏移 (px)" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <ui:NumberStepper x:Name="XOffsetStepper" Grid.Column="1" Minimum="-2000" Maximum="2000" Step="10" Decimals="0" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="280" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Y 偏移 (px)" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <ui:NumberStepper x:Name="YOffsetStepper" Grid.Column="1" Minimum="-2000" Maximum="2000" Step="10" Decimals="0" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- 调试 -->
                    <Border x:Name="SectionDebug" Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="维护调试" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="查看运行诊断、调整频谱参数、清理缓存或重新匹配歌词。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,5,0,14" />
                            <TextBlock Text="诊断工具" Style="{StaticResource SettingsFirstGroupTitleStyle}" />
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="SMTC 时间轴监视器" FontWeight="SemiBold" />
                                        <TextBlock Text="用于观察播放器时间轴数据，排查同步问题。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="EnableSmtcTimelineMonitorCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="频谱调试" FontWeight="SemiBold" />
                                        <TextBlock Text="打开临时滑块面板，实时调整频谱响应参数。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                        <TextBlock x:Name="SpectrumTuningHint"
                                                   Text="频谱总开关已关闭，调参会保存，但当前不会显示频谱。"
                                                   Foreground="{StaticResource SettingsMutedBrush}"
                                                   FontSize="12"
                                                   Margin="0,6,0,0"
                                                   Visibility="Collapsed" />
                                    </StackPanel>
                                    <Button x:Name="SpectrumTuningButton" Grid.Column="1" Content="打开调试" Style="{StaticResource SettingsPrimaryButtonStyle}" Height="38" MinWidth="96" />
                                </Grid>
                            </Border>
                            <TextBlock Text="歌词维护" Style="{StaticResource SettingsGroupTitleStyle}" />
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="当前歌词命中详情" FontWeight="SemiBold" />
                                        <TextBlock x:Name="LyricDiagnosticsText"
                                                   Text="暂无歌词匹配信息。"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource SettingsMutedBrush}"
                                                   FontSize="12"
                                                   Margin="0,6,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button x:Name="RefreshLyricDiagnosticsButton" Content="刷新" Style="{StaticResource SettingsPrimaryButtonStyle}" Height="38" MinWidth="72" />
                                        <Button x:Name="RematchLyricsButton" Content="重新匹配" Style="{StaticResource SettingsPrimaryButtonStyle}" Height="38" MinWidth="92" Margin="8,0,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="歌词缓存" FontWeight="SemiBold" />
                                        <TextBlock Text="清除后首次重新匹配会稍慢。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                        <TextBlock x:Name="ClearCacheStatusText"
                                                   Foreground="{StaticResource SettingsMutedBrush}"
                                                   FontSize="12"
                                                   Margin="0,6,0,0" />
                                    </StackPanel>
                                    <Button x:Name="ClearCacheButton" Grid.Column="1" Content="清除缓存" Style="{StaticResource SettingsDangerButtonStyle}" Height="38" MinWidth="96" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- 关于 -->
                    <Border x:Name="SectionAbout" Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="关于更新" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="查看版本信息，设置更新检查，并打开项目仓库。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,5,0,14" />
                            <TextBlock Text="版本信息" Style="{StaticResource SettingsFirstGroupTitleStyle}" />
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="TaskbarLyrics Light" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock x:Name="AppVersionText"
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource SettingsMutedBrush}"
                                               FontSize="12" />
                                    <TextBlock Text="原生 WPF 轻量版，共享 TaskbarLyrics.Core 歌词检索逻辑。"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource SettingsMutedBrush}"
                                               FontSize="12"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                            <TextBlock Text="更新检查" Style="{StaticResource SettingsGroupTitleStyle}" />
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="自动检查更新" FontWeight="SemiBold" />
                                        <TextBlock Text="每天最多检查一次，发现新版本时通过系统通知提醒。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="AutoCheckUpdatesCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <StackPanel>
                                    <Button x:Name="CheckUpdateButton"
                                            Content="检查更新"
                                            Style="{StaticResource SettingsPrimaryButtonStyle}"
                                            Height="38"
                                            MinWidth="120"
                                            HorizontalAlignment="Left"
                                            Click="CheckUpdateButton_Click" />
                                    <TextBlock x:Name="UpdateStatusText"
                                               Margin="0,10,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource SettingsMutedBrush}"
                                               FontSize="12" />
                                    <Button x:Name="OpenRepositoryButton"
                                            Margin="0,12,0,0"
                                            Content="打开 GitHub 仓库"
                                            Style="{StaticResource SettingsPrimaryButtonStyle}"
                                            Height="38"
                                            MinWidth="160"
                                            HorizontalAlignment="Left"
                                            Click="OpenRepositoryButton_Click" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
