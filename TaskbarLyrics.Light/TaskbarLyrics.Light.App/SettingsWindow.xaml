<Window x:Class="TaskbarLyrics.Light.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:TaskbarLyrics.Light.App.Ui"
        Title="TaskbarLyrics Light - 设置"
        Width="1280"
        Height="860"
        MinWidth="1080"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="#070E1D"
        Foreground="#F8FAFC"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Ui/SettingsTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="#070E1D">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="248" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 侧边栏 -->
        <Border Grid.Column="0"
                Background="#F20D182B"
                BorderBrush="#2E78A0FF"
                BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="24,24,14,20">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="28" Height="28"
                                BorderBrush="#4D7AFF"
                                BorderThickness="2"
                                Margin="0,0,12,0">
                            <TextBlock Text="◎"
                                       Foreground="#55A2FF"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock x:Name="BrandTitle"
                                   Text="TaskbarLyrics"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <Button x:Name="SidebarToggleButton"
                        DockPanel.Dock="Bottom"
                        Content="‹"
                        Width="36"
                        Height="36"
                        Margin="23,0,0,18"
                        HorizontalAlignment="Left"
                        Background="#8A0B1528"
                        Foreground="#8FB0FF"
                        BorderBrush="#2478A0FF"
                        BorderThickness="1"
                        FontSize="22"
                        Cursor="Hand" />

                <StackPanel Margin="14,0,14,0">
                    <RadioButton x:Name="NavPlayers" Style="{StaticResource SettingsNavButtonStyle}" GroupName="Nav" IsChecked="True" Checked="Nav_Checked">
                        <StackPanel Orientation="Horizontal"><TextBlock Width="28" Text="▷" /><TextBlock Text="播放源" FontWeight="SemiBold" /></StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavLyrics" Style="{StaticResource SettingsNavButtonStyle}" GroupName="Nav" Checked="Nav_Checked">
                        <StackPanel Orientation="Horizontal"><TextBlock Width="28" Text="Aa" /><TextBlock Text="歌词与本地" FontWeight="SemiBold" /></StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavAppearance" Style="{StaticResource SettingsNavButtonStyle}" GroupName="Nav" Checked="Nav_Checked">
                        <StackPanel Orientation="Horizontal"><TextBlock Width="28" Text="◌" /><TextBlock Text="显示与外观" FontWeight="SemiBold" /></StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavLayout" Style="{StaticResource SettingsNavButtonStyle}" GroupName="Nav" Checked="Nav_Checked">
                        <StackPanel Orientation="Horizontal"><TextBlock Width="28" Text="▦" /><TextBlock Text="窗口布局" FontWeight="SemiBold" /></StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavDebug" Style="{StaticResource SettingsNavButtonStyle}" GroupName="Nav" Checked="Nav_Checked">
                        <StackPanel Orientation="Horizontal"><TextBlock Width="28" Text="♢" /><TextBlock Text="维护调试" FontWeight="SemiBold" /></StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavAbout" Style="{StaticResource SettingsNavButtonStyle}" GroupName="Nav" Checked="Nav_Checked">
                        <StackPanel Orientation="Horizontal"><TextBlock Width="28" Text="i" /><TextBlock Text="关于更新" FontWeight="SemiBold" /></StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 主区域 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="98" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Margin="40,18,36,0">
                <StackPanel VerticalAlignment="Top">
                    <TextBlock Text="设置" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="按功能域管理设置：播放源、歌词与本地库、显示与外观、窗口布局、维护调试。"
                               Foreground="{StaticResource SettingsMutedBrush}"
                               FontSize="12"
                               Margin="0,7,0,0" />
                </StackPanel>
                <Button x:Name="ResetDefaultsButton"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Style="{StaticResource SettingsPrimaryButtonStyle}"
                        Content="↺  恢复默认设置" />
            </Grid>

            <ScrollViewer x:Name="ContentScroll"
                          Grid.Row="1"
                          Margin="40,0,36,36"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          PanningMode="VerticalOnly"
                          CanContentScroll="False"
                          ScrollChanged="ContentScroll_ScrollChanged">
                <StackPanel>
                    <!--
                    设置归类规则：
                    播放源：播放器启用与识别优先级。
                    歌词与本地库：窗口自动显示、歌词同步、本地歌词/封面来源。
                    显示与外观：频谱、字体颜色、封面呈现、背景边框和动效。
                    窗口布局：自动尺寸、锚点、偏移和置顶层级。
                    维护调试：诊断、调参、缓存和重新匹配。
                    关于更新：版本、更新检查和项目入口。
                    -->
                    <!-- 播放器 -->
                    <Border x:Name="SectionPlayers" Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="播放源" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="选择要监听的音乐播放器，并设置识别优先级。"
                                       Foreground="{StaticResource SettingsMutedBrush}"
                                       FontSize="12"
                                       Margin="0,5,0,14" />
                            <TextBlock Text="启用播放器" Style="{StaticResource SettingsFirstGroupTitleStyle}" />
                            <UniformGrid Columns="2" Margin="0,0,0,10">
                                <Border Style="{StaticResource SettingsRowCardStyle}" Margin="0,0,6,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Image x:Name="QQIcon" Width="32" Height="32" Margin="0,0,13,0" />
                                        <TextBlock Grid.Column="1" Text="QQ音乐" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <CheckBox x:Name="EnableQQMusicCheck" Grid.Column="2" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingsRowCardStyle}" Margin="6,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Image x:Name="NeteaseIcon" Width="32" Height="32" Margin="0,0,13,0" />
                                        <TextBlock Grid.Column="1" Text="网易云音乐" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <CheckBox x:Name="EnableNeteaseCheck" Grid.Column="2" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingsRowCardStyle}" Margin="0,0,6,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Image x:Name="KugouIcon" Width="32" Height="32" Margin="0,0,13,0" />
                                        <TextBlock Grid.Column="1" Text="酷狗音乐" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <CheckBox x:Name="EnableKugouCheck" Grid.Column="2" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingsRowCardStyle}" Margin="6,0,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Image x:Name="SpotifyIcon" Width="32" Height="32" Margin="0,0,13,0" />
                                        <TextBlock Grid.Column="1" Text="Spotify" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <CheckBox x:Name="EnableSpotifyCheck" Grid.Column="2" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                    </Grid>
                                </Border>
                            </UniformGrid>
                            <TextBlock Text="识别优先级" Style="{StaticResource SettingsGroupTitleStyle}" />
                            <ui:SourceOrderList x:Name="SourceOrderList" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- 歌词 -->
                    <Border x:Name="SectionLyrics" Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="歌词与本地库" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="管理歌词窗口行为、歌词同步、本地歌词和本地封面来源。"
                                       Foreground="{StaticResource SettingsMutedBrush}"
                                       FontSize="12"
                                       Margin="0,5,0,14" />
                            <TextBlock Text="启动与自动显示" Style="{StaticResource SettingsFirstGroupTitleStyle}" />
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="启动时显示歌词" FontWeight="SemiBold" />
                                        <TextBlock Text="应用启动后自动显示歌词悬浮窗口。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="ShowLyricsOnStartupCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="开机自启动" FontWeight="SemiBold" />
                                        <TextBlock Text="登录 Windows 后自动在后台运行（托盘图标）。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="StartWithWindowsCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="播放器打开时显示歌词" FontWeight="SemiBold" />
                                        <TextBlock Text="检测到已启用的音乐播放器并开始播放时，自动显示歌词窗口。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="AutoShowLyricsWhenPlayerOpensCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="播放器关闭时隐藏歌词" FontWeight="SemiBold" />
                                        <TextBlock Text="所有已启用播放器均停止或无播放会话时，自动隐藏歌词窗口。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="AutoHideLyricsWhenPlayerClosesCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border x:Name="StartupVisibilityHintRow"
                                    Style="{StaticResource SettingsRowCardStyle}"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="StartupVisibilityHint"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource SettingsMutedBrush}"
                                           FontSize="12" />
                            </Border>
                            <TextBlock Text="歌词同步" Style="{StaticResource SettingsGroupTitleStyle}" />
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="全局歌词偏移 (ms)" FontWeight="SemiBold" />
                                        <TextBlock Text="正数延后歌词，负数提前歌词。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <ui:NumberStepper x:Name="LyricOffsetStepper" Grid.Column="1" Minimum="-5000" Maximum="5000" Step="50" Decimals="0" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="QQ 音乐偏移 (ms)" FontWeight="SemiBold" />
                                        <TextBlock Text="会与全局偏移叠加。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <ui:NumberStepper x:Name="QqMusicLyricOffsetStepper" Grid.Column="1" Minimum="-5000" Maximum="5000" Step="50" Decimals="0" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="网易云偏移 (ms)" FontWeight="SemiBold" />
                                        <TextBlock Text="会与全局偏移叠加。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <ui:NumberStepper x:Name="NeteaseLyricOffsetStepper" Grid.Column="1" Minimum="-5000" Maximum="5000" Step="50" Decimals="0" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="酷狗偏移 (ms)" FontWeight="SemiBold" />
                                        <TextBlock Text="会与全局偏移叠加。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <ui:NumberStepper x:Name="KugouLyricOffsetStepper" Grid.Column="1" Minimum="-5000" Maximum="5000" Step="50" Decimals="0" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Spotify 偏移 (ms)" FontWeight="SemiBold" />
                                        <TextBlock Text="会与全局偏移叠加。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <ui:NumberStepper x:Name="SpotifyLyricOffsetStepper" Grid.Column="1" Minimum="-5000" Maximum="5000" Step="50" Decimals="0" />
                                </Grid>
                            </Border>
                            <TextBlock Text="本地歌词与封面来源" Style="{StaticResource SettingsGroupTitleStyle}" />
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="显示歌词封面" FontWeight="SemiBold" />
                                        <TextBlock Text="在歌词窗口左侧显示当前歌曲封面。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="ShowCoverImageCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="优先使用本地歌词" FontWeight="SemiBold" />
                                        <TextBlock Text="播放本地音乐时，先从下方目录中匹配同名歌词文件。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="EnableLocalLyricsCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="LocalLyricsModeLabel" Text="本地歌词策略" FontWeight="SemiBold" />
                                        <TextBlock x:Name="LocalLyricsModeHint" Text="控制本地歌词参与匹配的时机。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <ComboBox x:Name="LocalLyricsModeCombo" Grid.Column="1" Style="{StaticResource SettingsComboBoxStyle}">
                                        <ComboBoxItem Content="本地优先" Tag="PreferLocal" />
                                        <ComboBoxItem Content="在线失败后使用" Tag="OnlineFallback" />
                                    </ComboBox>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="LocalCoverModeLabel" Text="本地封面策略" FontWeight="SemiBold" />
                                        <TextBlock x:Name="LocalCoverModeHint" Text="控制本地封面和在线封面的优先级。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <ComboBox x:Name="LocalCoverModeCombo" Grid.Column="1" Style="{StaticResource SettingsComboBoxStyle}">
                                        <ComboBoxItem Content="在线优先" Tag="OnlineFirst" />
                                        <ComboBoxItem Content="本地优先" Tag="LocalFirst" />
                                        <ComboBoxItem Content="仅在线" Tag="OnlineOnly" />
                                        <ComboBoxItem Content="仅本地" Tag="LocalOnly" />
                                    </ComboBox>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="本地音乐目录" FontWeight="SemiBold" />
                                    <TextBlock Text="一行一个目录，支持同名 .lrc / .qrc / .krc 歌词文件。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,10" />
                                    <TextBox x:Name="LocalMusicFoldersBox"
                                             AcceptsReturn="True"
                                             MinHeight="72"
                                             VerticalScrollBarVisibility="Auto"
                                             TextWrapping="Wrap"
                                             FontFamily="Consolas, Courier New"
                                             Background="#F2081122"
                                             Foreground="#F8FAFC"
                                             CaretBrush="#F8FAFC"
                                             SelectionBrush="#805B7CFA"
                                             BorderBrush="#2978A0FF"
                                             BorderThickness="1"
                                             Padding="10,8" />
                                    <DockPanel Margin="0,10,0,0">
                                        <Button x:Name="AddLocalFolderButton"
                                                DockPanel.Dock="Right"
                                                Content="选择目录"
                                                Style="{StaticResource SettingsPrimaryButtonStyle}"
                                                Height="34"
                                                MinWidth="96" />
                                        <TextBlock x:Name="LocalFoldersStatusText"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource SettingsMutedBrush}"
                                                   FontSize="12" />
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- 外观 -->
                    <Border x:Name="SectionAppearance" Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="显示与外观" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="控制歌词窗口展示内容、字体颜色、封面样式、背景和动效。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,5,0,14" />
                            <TextBlock Text="频谱显示" Style="{StaticResource SettingsFirstGroupTitleStyle}" />
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="启用频谱" FontWeight="SemiBold" />
                                        <TextBlock Text="总开关。关闭后纯音乐、无歌词和强制频谱都不会显示频谱。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="EnableSpectrumCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="纯音乐时显示频谱" FontWeight="SemiBold" />
                                        <TextBlock Text="歌曲识别为纯音乐时，在歌词区域显示实时频谱。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="EnablePureMusicSpectrumCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="ShowSpectrumWhenLyricsAvailableLabel" Text="有歌词时也显示频谱" FontWeight="SemiBold" />
                                        <TextBlock x:Name="ShowSpectrumWhenLyricsAvailableHint" Text="歌曲已有可用歌词时，也用频谱替代歌词显示。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="ShowSpectrumWhenLyricsAvailableCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="未检索到歌词时显示频谱" FontWeight="SemiBold" />
                                        <TextBlock Text="歌词源没有返回可用歌词时，用频谱替代“暂未找到歌词”。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="ShowSpectrumWhenLyricsNotFoundCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
