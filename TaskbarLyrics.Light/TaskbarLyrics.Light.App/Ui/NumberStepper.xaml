<UserControl x:Class="TaskbarLyrics.Light.App.Ui.NumberStepper"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="150"
             Height="38"
             HorizontalAlignment="Stretch">
    <Border Style="{DynamicResource SettingsStepperChromeStyle}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="32" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="32" />
            </Grid.ColumnDefinitions>
            <Button x:Name="DecreaseButton" Grid.Column="0" Content="-" Style="{DynamicResource SettingsStepperButtonStyle}" />
            <TextBox x:Name="ValueBox"
                     Grid.Column="1"
                     Margin="4,0"
                     Style="{DynamicResource SettingsStepperInputStyle}"
                     TextAlignment="Center" />
            <Button x:Name="IncreaseButton" Grid.Column="2" Content="+" Style="{DynamicResource SettingsStepperButtonStyle}" />
        </Grid>
    </Border>
</UserControl>
